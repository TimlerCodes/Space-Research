<UserControl x:Class="SpaceResearchProject.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#11141A">
    
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="DEEP SPACE RESEARCH LAB" 
                       FontSize="28" FontWeight="Bold" Foreground="#4A90E2"/>
            <TextBlock Text="Astrophysics Data &amp; Signal Processing Suite" 
                       FontSize="14" Foreground="#7F8C8D" Margin="0,5,0,0"/>
            <Separator Background="#2C3E50" Margin="0,15,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Project Abstract:" FontSize="16" FontWeight="SemiBold" Foreground="#ECF0F1" Margin="0,0,0,10"/>
            <TextBlock Text="This workstation handles the ingestion, processing, and filtering of telemetry strings captured by deep-space radio telescope arrays. Current objectives focus on isolating anomalous coherent data structures from background cosmic microwave radiation noise patterns." 
                       FontSize="14" Foreground="#BDC3C7" TextWrapping="Wrap" LineHeight="22"/>
            
            <Border Background="#1C2331" CornerRadius="4" Padding="15" Margin="0,25,0,0" BorderBrush="#2E3C56" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="SYSTEM STATUS: ONLINE" Foreground="#2ECC71" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="• Connection to hardware array: STABLE" Foreground="#BDC3C7" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Initialize Analysis System" 
                    Width="220" Height="45" 
                    Background="#4A90E2" Foreground="White" 
                    FontWeight="Bold" FontSize="14"
                    Cursor="Hand"
                    Click="InitializeButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>